# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# content factory output
/output/

# fastapi backend runtime
/backend/metis.db
/backend/.venv/
**/__pycache__/
/backend/**/__pycache__/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.cursor/debug*.log
evidence/

# env files (can opt-in for committing if needed)
.env*
!deploy/.env.staging.example
!deploy/.env.production.example
!deploy/production/.env.production.example
!backend/.env.example

# staging compose runtime artifacts
deploy/volumes/
deploy/logs/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

METIS_ENV=development
METIS_SEED_EMAIL=admin@example.com
METIS_SEED_PASSWORD=change-me

# APF operator gateway credentials (POST /operator/login, GET /api/operator/session)
APF_OPERATOR_EMAIL=operator@example.com
APF_OPERATOR_PASSWORD=change-me
